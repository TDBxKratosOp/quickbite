rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.email is string &&
               data.name is string &&
               data.name.size() > 0 &&
               data.name.size() <= 100;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'deliveryAddress', 'pincode', 'createdAt', 'isAdmin', 'uid', 'email']) &&
                      (request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false));
    }

    // Orders
    match /orders/{orderId} {
      function isValidOrder(data) {
        return isSignedIn() &&
               data.userId == request.auth.uid &&
               data.total is number &&
               data.total > 0 &&
               data.status in ['pending', 'confirmed', 'preparing', 'out-for-delivery', 'delivered', 'cancelled'] &&
               data.items is list;
      }

      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(request.resource.data);
      allow update: if isOwner(resource.data.userId) || isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      function isValidReview(data) {
        return isSignedIn() &&
               data.userId == request.auth.uid &&
               data.rating is number && data.rating >= 1 && data.rating <= 5 &&
               data.comment is string &&
               data.restaurantId is string && data.orderId is string;
      }

      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && isValidReview(request.resource.data);
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Coupons
    match /coupons/{couponId} {
      function isValidCoupon(data) {
        return data.code is string && data.code.size() <= 20 &&
               data.discountPercent is number && data.discountPercent >= 0 && data.discountPercent <= 100 &&
               data.isActive is bool;
      }

      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidCoupon(request.resource.data));
    }
  }
}
